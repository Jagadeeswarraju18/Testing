{
    "routes": [
        {
            "src": "/assets/(.*)",
            "headers": {
                "cache-control": "public, max-age=31536000, immutable"
            },
            "continue": true
        },
        {
            "src": "/(index.html|sw.js|manifest.json)",
            "headers": {
                "cache-control": "public, max-age=0, must-revalidate"
            },
            "continue": true
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/.*",
            "dest": "/index.html"
        }
    ]
}